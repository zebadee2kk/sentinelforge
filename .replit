modules = ["python-3.12", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "postgresql", "redis"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 6379
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "redis-server --daemonize yes --logfile /tmp/redis.log --port 6379 && sleep 1 && cd services/api && PYTHONPATH=src gunicorn -w 2 -k uvicorn.workers.UvicornWorker --bind 0.0.0.0:5000 src.main:app"]
