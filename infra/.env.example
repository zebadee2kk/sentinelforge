# SentinelForge Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================================================
# DOMAIN & TLS
# ============================================================================
DOMAIN=sentinelforge.local
ACME_EMAIL=admin@sentinelforge.local

# ============================================================================
# POSTGRES
# ============================================================================
POSTGRES_PASSWORD=changeme_postgres_password_min_32_chars

# ============================================================================
# MINIO
# ============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio_password_min_32_chars

# ============================================================================
# AUTHENTIK
# ============================================================================
# Generate with: openssl rand -base64 64 | tr -d '\n'
AUTHENTIK_SECRET_KEY=
AUTHENTIK_BOOTSTRAP_PASSWORD=changeme_authentik_admin_password
# Generate with: openssl rand -base64 32 | tr -d '\n'
AUTHENTIK_BOOTSTRAP_TOKEN=
AUTHENTIK_POSTGRES_PASSWORD=changeme_authentik_postgres_password

# ============================================================================
# GRAFANA
# ============================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password
# Configure after Authentik setup
GRAFANA_OAUTH_CLIENT_ID=
GRAFANA_OAUTH_CLIENT_SECRET=

# ============================================================================
# LLM PROVIDERS (Phase 2+)
# ============================================================================
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OLLAMA_ENDPOINT=http://your-gpu-vm:11434

# ============================================================================
# GITHUB (Phase 2+)
# ============================================================================
# GITHUB_TOKEN=

# ============================================================================
# POLICY ENGINE (Phase 3+)
# ============================================================================
# OPA_POLICY_BUNDLE_URL=
# CERBOS_ENDPOINT=
